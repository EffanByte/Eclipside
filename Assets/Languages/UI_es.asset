    m_Metadata:
      m_Items: []
  - m_Id: 7912345795076096
    m_Localized: El eclipse no espera a nadie. Elige una mejora antes de que llegue
      la siguiente oleada.
    m_Metadata:
      m_Items: []
  - m_Id: 7912345795076097
    m_Localized: Elige Una Bendicion
    m_Metadata:
      m_Items: []
  - m_Id: 7912345795076098
    m_Localized: Dano Cuerpo a Cuerpo
    m_Metadata:
      m_Items: []
  - m_Id: 7912345795076099
    m_Localized: +10% al dano de tus armas cuerpo a cuerpo.
    m_Metadata:
      m_Items: []
  - m_Id: 7912345795076100
