  m_TableData:
  - m_Id: 2067010985984
    m_Localized: ECLIPSIDE
    m_Metadata:
      m_Items: []
  - m_Id: 2067115843584
    m_Localized: Desciende por biomas fracturados, define tu equipamiento y sobrevive
      al eclipse.
    m_Metadata:
      m_Items: []
  - m_Id: 2067124232192
    m_Localized: Elige Tu Camino
    m_Metadata:
      m_Items: []
  - m_Id: 2067124232193
    m_Localized: Una gran aventura empieza con una eleccion consciente.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426496
    m_Localized: Iniciar Partida
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426497
    m_Localized: Elige tu personaje y entra en la siguiente partida.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426498
    m_Localized: Gacha
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426499
    m_Localized: Gasta meteoritos y amplia tu plantel.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426500
    m_Localized: Misiones
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426501
    m_Localized: Sigue objetivos diarios y reclama recompensas.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426502
    m_Localized: Logros
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426503
    m_Localized: Revisa el progreso a largo plazo y tus hitos.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426504
    m_Localized: Desafios
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426505
    m_Localized: Activa modificadores de partida y gana prestigio.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426506
    m_Localized: Ajustes
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426507
    m_Localized: Ajusta el idioma y las preferencias del menu.
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426508
    m_Localized: Seleccionar Personaje
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426509
    m_Localized: 'Seleccionado: Ninguno'
    m_Metadata:
      m_Items: []
