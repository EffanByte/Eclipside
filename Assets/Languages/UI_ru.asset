  - m_Id: 2067010985984
    m_Localized: ECLIPSIDE
    m_Metadata:
      m_Items: []
  - m_Id: 2067115843584
    m_Localized: "\u041F\u043E\u0433\u0440\u0443\u0436\u0430\u0439\u0442\u0435\u0441\u044C
      \u0432 \u0440\u0430\u0441\u043A\u043E\u043B\u043E\u0442\u044B\u0435 \u0431\u0438\u043E\u043C\u044B,
      \u0441\u043E\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0431\u0438\u043B\u0434
      \u0438 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0438\u0442\u0435 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 2067124232192
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0421\u0432\u043E\u0439
      \u041F\u0443\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 2067124232193
    m_Localized: "\u0421\u0438\u043B\u044C\u043D\u044B\u0439 \u0437\u0430\u0431\u0435\u0433
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0441 \u043E\u0441\u043E\u0437\u043D\u0430\u043D\u043D\u043E\u0433\u043E
      \u0432\u044B\u0431\u043E\u0440\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426496
    m_Localized: "\u041D\u0430\u0447\u0430\u0442\u044C \u0417\u0430\u0431\u0435\u0433"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426497
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430
      \u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0439\u0442\u0435\u0441\u044C
      \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0437\u0430\u0431\u0435\u0433."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426498
    m_Localized: "\u0413\u0430\u0447\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426499
    m_Localized: "\u0422\u0440\u0430\u0442\u044C\u0442\u0435 \u043C\u0435\u0442\u0435\u043E\u0440\u0438\u0442\u044B
      \u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u0439\u0442\u0435 \u0441\u0432\u043E\u0439
      \u0441\u043E\u0441\u0442\u0430\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426500
    m_Localized: "\u0417\u0430\u0434\u0430\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426501
    m_Localized: "\u0421\u043B\u0435\u0434\u0438\u0442\u0435 \u0437\u0430 \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u044B\u043C\u0438
      \u0446\u0435\u043B\u044F\u043C\u0438 \u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u0439\u0442\u0435
      \u043D\u0430\u0433\u0440\u0430\u0434\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426502
    m_Localized: "\u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426503
    m_Localized: "\u041F\u0440\u043E\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0439\u0442\u0435
      \u0434\u043E\u043B\u0433\u043E\u0441\u0440\u043E\u0447\u043D\u044B\u0439 \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441
      \u0438 \u0432\u0430\u0436\u043D\u044B\u0435 \u0432\u0435\u0445\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426504
    m_Localized: "\u0418\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426505
    m_Localized: "\u0412\u043A\u043B\u044E\u0447\u0430\u0439\u0442\u0435 \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0442\u043E\u0440\u044B
      \u0437\u0430\u0431\u0435\u0433\u0430 \u0438 \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0439\u0442\u0435
      \u0441\u043B\u0430\u0432\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426506
    m_Localized: "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426507
    m_Localized: "\u0418\u0437\u043C\u0435\u043D\u0438\u0442\u0435 \u044F\u0437\u044B\u043A
      \u0438 \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u044B \u043C\u0435\u043D\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426508
    m_Localized: "\u0412\u044B\u0431\u043E\u0440 \u041F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426509
    m_Localized: "\u0412\u044B\u0431\u0440\u0430\u043D\u043E: \u041D\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 2067128426510
    m_Localized: "\u0412\u044B\u0431\u0440\u0430\u043D\u043E: {0} ({1})"
